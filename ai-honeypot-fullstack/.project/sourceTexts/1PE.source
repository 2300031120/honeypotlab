        "type": "text",
        "edits": [],
        "vref": "1PE 1:14",
        "bookCode": "1PE",
        "chapter": 1,
        "verse": "14",
        "cellLabel": "14",
        "originalText": "ὡς τέκνα ὑπακοῆς, μὴ συσχηματιζόμενοι ταῖς πρότερον ἐν τῇ ἀγνοίᾳ ὑμῶν ἐπιθυμίαις,",
        "fileName": "1PE.macula",
        "chapterNumber": "1",
