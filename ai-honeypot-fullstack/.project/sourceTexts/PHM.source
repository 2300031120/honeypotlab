        "type": "text",
        "edits": [],
        "vref": "PHM 1:15",
        "bookCode": "PHM",
        "chapter": 1,
        "verse": "15",
        "cellLabel": "15",
        "originalText": "τάχα γὰρ διὰ τοῦτο ἐχωρίσθη πρὸς ὥραν ἵνα αἰώνιον αὐτὸν ἀπέχῃς,",
        "fileName": "PHM.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "τάχα γὰρ διὰ τοῦτο ἐχωρίσθη πρὸς ὥραν ἵνα αἰώνιον αὐτὸν ἀπέχῃς,",
          "globalReferences": [
