          "globalReferences": [
            "PHM 1:14"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "τάχα γὰρ διὰ τοῦτο ἐχωρίσθη πρὸς ὥραν ἵνα αἰώνιον αὐτὸν ἀπέχῃς,",
      "languageId": "html",
      "metadata": {
