        "bookCode": "PHM",
        "chapter": 1,
        "verse": "17",
        "cellLabel": "17",
        "originalText": "Εἰ οὖν με ἔχεις κοινωνόν, προσλαβοῦ αὐτὸν ὡς ἐμέ.",
        "fileName": "PHM.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "Εἰ οὖν με ἔχεις κοινωνόν, προσλαβοῦ αὐτὸν ὡς ἐμέ.",
          "globalReferences": [
            "PHM 1:17"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "εἰ δέ τι ἠδίκησέν σε ἢ ὀφείλει, τοῦτο ἐμοὶ ἐλλόγα·",
      "languageId": "html",
      "metadata": {
