        "bookCode": "PHM",
        "chapter": 1,
        "verse": "12",
        "cellLabel": "12",
        "originalText": "ὃν ἀνέπεμψά σοι αὐτόν, τοῦτ’ ἔστιν τὰ ἐμὰ σπλάγχνα·",
        "fileName": "PHM.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "ὃν ἀνέπεμψά σοι αὐτόν, τοῦτ’ ἔστιν τὰ ἐμὰ σπλάγχνα·",
          "globalReferences": [
