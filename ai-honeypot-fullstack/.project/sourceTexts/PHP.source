        }
      }
    },
    {
      "kind": 2,
      "value": "ὅτι καὶ ἐν Θεσσαλονίκῃ καὶ ἅπαξ καὶ δὶς εἰς τὴν χρείαν μοι ἐπέμψατε.",
      "languageId": "html",
      "metadata": {
        "id": "b9eab5ed-99e9-42c8-8445-805aa979c7f6",
        "type": "text",
        "edits": [],
        "vref": "PHP 4:16",
        "bookCode": "PHP",
        "chapter": 4,
        "verse": "16",
        "cellLabel": "16",
        "originalText": "ὅτι καὶ ἐν Θεσσαλονίκῃ καὶ ἅπαξ καὶ δὶς εἰς τὴν χρείαν μοι ἐπέμψατε.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "ὅτι καὶ ἐν Θεσσαλονίκῃ καὶ ἅπαξ καὶ δὶς εἰς τὴν χρείαν μοι ἐπέμψατε.",
          "globalReferences": [
            "PHP 4:16"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "οὐχ ὅτι ἐπιζητῶ τὸ δόμα, ἀλλὰ ἐπιζητῶ τὸν καρπὸν τὸν πλεονάζοντα εἰς λόγον ὑμῶν.",
      "languageId": "html",
      "metadata": {
        "id": "bb8410a3-8184-40ed-ba7c-6d6c7cd99eb0",
        "type": "text",
        "edits": [],
        "vref": "PHP 4:17",
        "bookCode": "PHP",
        "chapter": 4,
        "verse": "17",
        "cellLabel": "17",
        "originalText": "οὐχ ὅτι ἐπιζητῶ τὸ δόμα, ἀλλὰ ἐπιζητῶ τὸν καρπὸν τὸν πλεονάζοντα εἰς λόγον ὑμῶν.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "οὐχ ὅτι ἐπιζητῶ τὸ δόμα, ἀλλὰ ἐπιζητῶ τὸν καρπὸν τὸν πλεονάζοντα εἰς λόγον ὑμῶν.",
          "globalReferences": [
            "PHP 4:17"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "ἀπέχω δὲ πάντα καὶ περισσεύω· πεπλήρωμαι δεξάμενος παρὰ Ἐπαφροδίτου τὰ παρ’ ὑμῶν, ὀσμὴν εὐωδίας, θυσίαν δεκτήν, εὐάρεστον τῷ θεῷ.",
      "languageId": "html",
      "metadata": {
        "id": "6c94f006-a849-4e7a-a8e2-a78a5f59b7b9",
        "type": "text",
        "edits": [],
        "vref": "PHP 4:18",
        "bookCode": "PHP",
        "chapter": 4,
        "verse": "18",
        "cellLabel": "18",
        "originalText": "ἀπέχω δὲ πάντα καὶ περισσεύω· πεπλήρωμαι δεξάμενος παρὰ Ἐπαφροδίτου τὰ παρ’ ὑμῶν, ὀσμὴν εὐωδίας, θυσίαν δεκτήν, εὐάρεστον τῷ θεῷ.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "ἀπέχω δὲ πάντα καὶ περισσεύω· πεπλήρωμαι δεξάμενος παρὰ Ἐπαφροδίτου τὰ παρ’ ὑμῶν, ὀσμὴν εὐωδίας, θυσίαν δεκτήν, εὐάρεστον τῷ θεῷ.",
          "globalReferences": [
            "PHP 4:18"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "ὁ δὲ θεός μου πληρώσει πᾶσαν χρείαν ὑμῶν κατὰ τὸ πλοῦτος αὐτοῦ ἐν δόξῃ ἐν Χριστῷ Ἰησοῦ.",
      "languageId": "html",
      "metadata": {
        "id": "1cd3d6a4-2446-4d88-a1c4-00dd7a228b04",
        "type": "text",
        "edits": [],
        "vref": "PHP 4:19",
        "bookCode": "PHP",
        "chapter": 4,
        "verse": "19",
        "cellLabel": "19",
        "originalText": "ὁ δὲ θεός μου πληρώσει πᾶσαν χρείαν ὑμῶν κατὰ τὸ πλοῦτος αὐτοῦ ἐν δόξῃ ἐν Χριστῷ Ἰησοῦ.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "ὁ δὲ θεός μου πληρώσει πᾶσαν χρείαν ὑμῶν κατὰ τὸ πλοῦτος αὐτοῦ ἐν δόξῃ ἐν Χριστῷ Ἰησοῦ.",
          "globalReferences": [
            "PHP 4:19"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "τῷ δὲ θεῷ καὶ πατρὶ ἡμῶν ἡ δόξα εἰς τοὺς αἰῶνας τῶν αἰώνων· ἀμήν.",
      "languageId": "html",
      "metadata": {
        "id": "1d3dc68a-ac68-4417-bb4f-80a4e10c75fe",
        "type": "text",
        "edits": [],
        "vref": "PHP 4:20",
        "bookCode": "PHP",
        "chapter": 4,
        "verse": "20",
        "cellLabel": "20",
        "originalText": "τῷ δὲ θεῷ καὶ πατρὶ ἡμῶν ἡ δόξα εἰς τοὺς αἰῶνας τῶν αἰώνων· ἀμήν.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "τῷ δὲ θεῷ καὶ πατρὶ ἡμῶν ἡ δόξα εἰς τοὺς αἰῶνας τῶν αἰώνων· ἀμήν.",
          "globalReferences": [
            "PHP 4:20"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "Ἀσπάσασθε πάντα ἅγιον ἐν Χριστῷ Ἰησοῦ. ἀσπάζονται ὑμᾶς οἱ σὺν ἐμοὶ ἀδελφοί.",
      "languageId": "html",
      "metadata": {
        "id": "de411540-93f1-42f6-bc00-76a709fa2782",
        "type": "text",
        "edits": [],
        "vref": "PHP 4:21",
        "bookCode": "PHP",
        "chapter": 4,
        "verse": "21",
        "cellLabel": "21",
        "originalText": "Ἀσπάσασθε πάντα ἅγιον ἐν Χριστῷ Ἰησοῦ. ἀσπάζονται ὑμᾶς οἱ σὺν ἐμοὶ ἀδελφοί.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "Ἀσπάσασθε πάντα ἅγιον ἐν Χριστῷ Ἰησοῦ. ἀσπάζονται ὑμᾶς οἱ σὺν ἐμοὶ ἀδελφοί.",
          "globalReferences": [
            "PHP 4:21"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "ἀσπάζονται ὑμᾶς πάντες οἱ ἅγιοι, μάλιστα δὲ οἱ ἐκ τῆς Καίσαρος οἰκίας.",
      "languageId": "html",
      "metadata": {
