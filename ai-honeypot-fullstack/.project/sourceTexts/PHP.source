    },
    {
      "kind": 2,
      "value": "Παῦλος καὶ Τιμόθεος δοῦλοι Χριστοῦ Ἰησοῦ πᾶσιν τοῖς ἁγίοις ἐν Χριστῷ Ἰησοῦ τοῖς οὖσιν ἐν Φιλίπποις σὺν ἐπισκόποις καὶ διακόνοις·",
      "languageId": "html",
      "metadata": {
        "id": "7bfa9387-4ad4-4beb-8b2c-186021a4f033",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:1",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "1",
        "cellLabel": "1",
        "originalText": "Παῦλος καὶ Τιμόθεος δοῦλοι Χριστοῦ Ἰησοῦ πᾶσιν τοῖς ἁγίοις ἐν Χριστῷ Ἰησοῦ τοῖς οὖσιν ἐν Φιλίπποις σὺν ἐπισκόποις καὶ διακόνοις·",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "Παῦλος καὶ Τιμόθεος δοῦλοι Χριστοῦ Ἰησοῦ πᾶσιν τοῖς ἁγίοις ἐν Χριστῷ Ἰησοῦ τοῖς οὖσιν ἐν Φιλίπποις σὺν ἐπισκόποις καὶ διακόνοις·",
          "globalReferences": [
            "PHP 1:1"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "χάρις ὑμῖν καὶ εἰρήνη ἀπὸ θεοῦ πατρὸς ἡμῶν καὶ κυρίου Ἰησοῦ Χριστοῦ.",
      "languageId": "html",
      "metadata": {
        "id": "7db4de9d-a30c-46a4-ab1b-6d49090dcf5f",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:2",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "2",
        "cellLabel": "2",
        "originalText": "χάρις ὑμῖν καὶ εἰρήνη ἀπὸ θεοῦ πατρὸς ἡμῶν καὶ κυρίου Ἰησοῦ Χριστοῦ.",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "χάρις ὑμῖν καὶ εἰρήνη ἀπὸ θεοῦ πατρὸς ἡμῶν καὶ κυρίου Ἰησοῦ Χριστοῦ.",
          "globalReferences": [
            "PHP 1:2"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "Εὐχαριστῶ τῷ θεῷ μου ἐπὶ πάσῃ τῇ μνείᾳ ὑμῶν",
      "languageId": "html",
      "metadata": {
        "id": "18fdc62f-c6ff-44eb-a361-2aca856b9b57",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:3",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "3",
        "cellLabel": "3",
        "originalText": "Εὐχαριστῶ τῷ θεῷ μου ἐπὶ πάσῃ τῇ μνείᾳ ὑμῶν",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "Εὐχαριστῶ τῷ θεῷ μου ἐπὶ πάσῃ τῇ μνείᾳ ὑμῶν",
          "globalReferences": [
            "PHP 1:3"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "πάντοτε ἐν πάσῃ δεήσει μου ὑπὲρ πάντων ὑμῶν, μετὰ χαρᾶς τὴν δέησιν ποιούμενος,",
      "languageId": "html",
      "metadata": {
        "id": "80137624-7dbd-4442-b335-a45ff4c5a3db",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:4",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "4",
        "cellLabel": "4",
        "originalText": "πάντοτε ἐν πάσῃ δεήσει μου ὑπὲρ πάντων ὑμῶν, μετὰ χαρᾶς τὴν δέησιν ποιούμενος,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "πάντοτε ἐν πάσῃ δεήσει μου ὑπὲρ πάντων ὑμῶν, μετὰ χαρᾶς τὴν δέησιν ποιούμενος,",
          "globalReferences": [
            "PHP 1:4"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "ἐπὶ τῇ κοινωνίᾳ ὑμῶν εἰς τὸ εὐαγγέλιον ἀπὸ τῆς πρώτης ἡμέρας ἄχρι τοῦ νῦν,",
      "languageId": "html",
      "metadata": {
        "id": "67c43e07-96d6-4770-b0e9-959ecd9d7614",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:5",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "5",
        "cellLabel": "5",
        "originalText": "ἐπὶ τῇ κοινωνίᾳ ὑμῶν εἰς τὸ εὐαγγέλιον ἀπὸ τῆς πρώτης ἡμέρας ἄχρι τοῦ νῦν,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "ἐπὶ τῇ κοινωνίᾳ ὑμῶν εἰς τὸ εὐαγγέλιον ἀπὸ τῆς πρώτης ἡμέρας ἄχρι τοῦ νῦν,",
          "globalReferences": [
            "PHP 1:5"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "πεποιθὼς αὐτὸ τοῦτο ὅτι ὁ ἐναρξάμενος ἐν ὑμῖν ἔργον ἀγαθὸν ἐπιτελέσει ἄχρι ἡμέρας Χριστοῦ Ἰησοῦ·",
      "languageId": "html",
      "metadata": {
        "id": "3f094be4-4e12-4761-b43c-4025fa541100",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:6",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "6",
        "cellLabel": "6",
        "originalText": "πεποιθὼς αὐτὸ τοῦτο ὅτι ὁ ἐναρξάμενος ἐν ὑμῖν ἔργον ἀγαθὸν ἐπιτελέσει ἄχρι ἡμέρας Χριστοῦ Ἰησοῦ·",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "πεποιθὼς αὐτὸ τοῦτο ὅτι ὁ ἐναρξάμενος ἐν ὑμῖν ἔργον ἀγαθὸν ἐπιτελέσει ἄχρι ἡμέρας Χριστοῦ Ἰησοῦ·",
          "globalReferences": [
            "PHP 1:6"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "καθώς ἐστιν δίκαιον ἐμοὶ τοῦτο φρονεῖν ὑπὲρ πάντων ὑμῶν, διὰ τὸ ἔχειν με ἐν τῇ καρδίᾳ ὑμᾶς, ἔν τε τοῖς δεσμοῖς μου καὶ ἐν τῇ ἀπολογίᾳ καὶ βεβαιώσει τοῦ εὐαγγελίου συγκοινωνούς μου τῆς χάριτος πάντας ὑμᾶς ὄντας·",
      "languageId": "html",
      "metadata": {
        "id": "6821ea91-289f-47d4-b33f-a2a01fee958f",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:7",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "7",
        "cellLabel": "7",
        "originalText": "καθώς ἐστιν δίκαιον ἐμοὶ τοῦτο φρονεῖν ὑπὲρ πάντων ὑμῶν, διὰ τὸ ἔχειν με ἐν τῇ καρδίᾳ ὑμᾶς, ἔν τε τοῖς δεσμοῖς μου καὶ ἐν τῇ ἀπολογίᾳ καὶ βεβαιώσει τοῦ εὐαγγελίου συγκοινωνούς μου τῆς χάριτος πάντας ὑμᾶς ὄντας·",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "καθώς ἐστιν δίκαιον ἐμοὶ τοῦτο φρονεῖν ὑπὲρ πάντων ὑμῶν, διὰ τὸ ἔχειν με ἐν τῇ καρδίᾳ ὑμᾶς, ἔν τε τοῖς δεσμοῖς μου καὶ ἐν τῇ ἀπολογίᾳ καὶ βεβαιώσει τοῦ εὐαγγελίου συγκοινωνούς μου τῆς χάριτος πάντας ὑμᾶς ὄντας·",
          "globalReferences": [
            "PHP 1:7"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "μάρτυς γάρ μου ὁ θεός, ὡς ἐπιποθῶ πάντας ὑμᾶς ἐν σπλάγχνοις Χριστοῦ Ἰησοῦ.",
      "languageId": "html",
      "metadata": {
        "id": "d80d302b-b187-4cd3-994f-3990a8bd5183",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:8",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "8",
        "cellLabel": "8",
        "originalText": "μάρτυς γάρ μου ὁ θεός, ὡς ἐπιποθῶ πάντας ὑμᾶς ἐν σπλάγχνοις Χριστοῦ Ἰησοῦ.",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "μάρτυς γάρ μου ὁ θεός, ὡς ἐπιποθῶ πάντας ὑμᾶς ἐν σπλάγχνοις Χριστοῦ Ἰησοῦ.",
          "globalReferences": [
            "PHP 1:8"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "καὶ τοῦτο προσεύχομαι ἵνα ἡ ἀγάπη ὑμῶν ἔτι μᾶλλον καὶ μᾶλλον περισσεύῃ ἐν ἐπιγνώσει καὶ πάσῃ αἰσθήσει,",
      "languageId": "html",
      "metadata": {
        "id": "05cb2a4b-9fe3-4590-b6a6-82361f114954",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:9",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "9",
        "cellLabel": "9",
        "originalText": "καὶ τοῦτο προσεύχομαι ἵνα ἡ ἀγάπη ὑμῶν ἔτι μᾶλλον καὶ μᾶλλον περισσεύῃ ἐν ἐπιγνώσει καὶ πάσῃ αἰσθήσει,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "καὶ τοῦτο προσεύχομαι ἵνα ἡ ἀγάπη ὑμῶν ἔτι μᾶλλον καὶ μᾶλλον περισσεύῃ ἐν ἐπιγνώσει καὶ πάσῃ αἰσθήσει,",
          "globalReferences": [
            "PHP 1:9"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "εἰς τὸ δοκιμάζειν ὑμᾶς τὰ διαφέροντα, ἵνα ἦτε εἰλικρινεῖς καὶ ἀπρόσκοποι εἰς ἡμέραν Χριστοῦ,",
      "languageId": "html",
      "metadata": {
        "id": "104da3df-8ad4-481a-96b7-8decdca0a605",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:10",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "10",
        "cellLabel": "10",
        "originalText": "εἰς τὸ δοκιμάζειν ὑμᾶς τὰ διαφέροντα, ἵνα ἦτε εἰλικρινεῖς καὶ ἀπρόσκοποι εἰς ἡμέραν Χριστοῦ,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "εἰς τὸ δοκιμάζειν ὑμᾶς τὰ διαφέροντα, ἵνα ἦτε εἰλικρινεῖς καὶ ἀπρόσκοποι εἰς ἡμέραν Χριστοῦ,",
          "globalReferences": [
            "PHP 1:10"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "πεπληρωμένοι καρπὸν δικαιοσύνης τὸν διὰ Ἰησοῦ Χριστοῦ εἰς δόξαν καὶ ἔπαινον θεοῦ.",
      "languageId": "html",
      "metadata": {
        "id": "f0fe82ae-c6da-4177-997c-21ef1ecc4d03",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:11",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "11",
        "cellLabel": "11",
        "originalText": "πεπληρωμένοι καρπὸν δικαιοσύνης τὸν διὰ Ἰησοῦ Χριστοῦ εἰς δόξαν καὶ ἔπαινον θεοῦ.",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "πεπληρωμένοι καρπὸν δικαιοσύνης τὸν διὰ Ἰησοῦ Χριστοῦ εἰς δόξαν καὶ ἔπαινον θεοῦ.",
          "globalReferences": [
            "PHP 1:11"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "Γινώσκειν δὲ ὑμᾶς βούλομαι, ἀδελφοί, ὅτι τὰ κατ’ ἐμὲ μᾶλλον εἰς προκοπὴν τοῦ εὐαγγελίου ἐλήλυθεν,",
      "languageId": "html",
      "metadata": {
        "id": "097568ec-78ed-40e6-b9b6-d8de3b94c347",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:12",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "12",
        "cellLabel": "12",
        "originalText": "Γινώσκειν δὲ ὑμᾶς βούλομαι, ἀδελφοί, ὅτι τὰ κατ’ ἐμὲ μᾶλλον εἰς προκοπὴν τοῦ εὐαγγελίου ἐλήλυθεν,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "Γινώσκειν δὲ ὑμᾶς βούλομαι, ἀδελφοί, ὅτι τὰ κατ’ ἐμὲ μᾶλλον εἰς προκοπὴν τοῦ εὐαγγελίου ἐλήλυθεν,",
          "globalReferences": [
            "PHP 1:12"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "ὥστε τοὺς δεσμούς μου φανεροὺς ἐν Χριστῷ γενέσθαι ἐν ὅλῳ τῷ πραιτωρίῳ καὶ τοῖς λοιποῖς πᾶσιν,",
      "languageId": "html",
      "metadata": {
        "id": "38c83ab6-ca12-4736-87f0-43ef51257ca8",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:13",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "13",
        "cellLabel": "13",
        "originalText": "ὥστε τοὺς δεσμούς μου φανεροὺς ἐν Χριστῷ γενέσθαι ἐν ὅλῳ τῷ πραιτωρίῳ καὶ τοῖς λοιποῖς πᾶσιν,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "ὥστε τοὺς δεσμούς μου φανεροὺς ἐν Χριστῷ γενέσθαι ἐν ὅλῳ τῷ πραιτωρίῳ καὶ τοῖς λοιποῖς πᾶσιν,",
          "globalReferences": [
            "PHP 1:13"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "καὶ τοὺς πλείονας τῶν ἀδελφῶν ἐν κυρίῳ πεποιθότας τοῖς δεσμοῖς μου περισσοτέρως τολμᾶν ἀφόβως τὸν λόγον λαλεῖν.",
      "languageId": "html",
      "metadata": {
        "id": "b61842c4-25a9-438f-9859-9b780e02019c",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:14",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "14",
        "cellLabel": "14",
        "originalText": "καὶ τοὺς πλείονας τῶν ἀδελφῶν ἐν κυρίῳ πεποιθότας τοῖς δεσμοῖς μου περισσοτέρως τολμᾶν ἀφόβως τὸν λόγον λαλεῖν.",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "καὶ τοὺς πλείονας τῶν ἀδελφῶν ἐν κυρίῳ πεποιθότας τοῖς δεσμοῖς μου περισσοτέρως τολμᾶν ἀφόβως τὸν λόγον λαλεῖν.",
          "globalReferences": [
            "PHP 1:14"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "Τινὲς μὲν καὶ διὰ φθόνον καὶ ἔριν, τινὲς δὲ καὶ δι’ εὐδοκίαν τὸν Χριστὸν κηρύσσουσιν·",
      "languageId": "html",
      "metadata": {
        "id": "3e58697a-e73f-495d-b1d5-77019108be06",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:15",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "15",
        "cellLabel": "15",
        "originalText": "Τινὲς μὲν καὶ διὰ φθόνον καὶ ἔριν, τινὲς δὲ καὶ δι’ εὐδοκίαν τὸν Χριστὸν κηρύσσουσιν·",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "Τινὲς μὲν καὶ διὰ φθόνον καὶ ἔριν, τινὲς δὲ καὶ δι’ εὐδοκίαν τὸν Χριστὸν κηρύσσουσιν·",
          "globalReferences": [
            "PHP 1:15"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "οἱ μὲν ἐξ ἀγάπης, εἰδότες ὅτι εἰς ἀπολογίαν τοῦ εὐαγγελίου κεῖμαι,",
      "languageId": "html",
      "metadata": {
        "id": "82608062-d387-4c12-9d65-53ee743e9569",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:16",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "16",
        "cellLabel": "16",
        "originalText": "οἱ μὲν ἐξ ἀγάπης, εἰδότες ὅτι εἰς ἀπολογίαν τοῦ εὐαγγελίου κεῖμαι,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "οἱ μὲν ἐξ ἀγάπης, εἰδότες ὅτι εἰς ἀπολογίαν τοῦ εὐαγγελίου κεῖμαι,",
          "globalReferences": [
            "PHP 1:16"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "οἱ δὲ ἐξ ἐριθείας τὸν Χριστὸν καταγγέλλουσιν, οὐχ ἁγνῶς, οἰόμενοι θλῖψιν ἐγείρειν τοῖς δεσμοῖς μου.",
      "languageId": "html",
      "metadata": {
        "id": "0c6a4786-8778-4d22-bbfb-8459f342fab3",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:17",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "17",
        "cellLabel": "17",
        "originalText": "οἱ δὲ ἐξ ἐριθείας τὸν Χριστὸν καταγγέλλουσιν, οὐχ ἁγνῶς, οἰόμενοι θλῖψιν ἐγείρειν τοῖς δεσμοῖς μου.",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "οἱ δὲ ἐξ ἐριθείας τὸν Χριστὸν καταγγέλλουσιν, οὐχ ἁγνῶς, οἰόμενοι θλῖψιν ἐγείρειν τοῖς δεσμοῖς μου.",
          "globalReferences": [
            "PHP 1:17"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "τί γάρ; πλὴν ὅτι παντὶ τρόπῳ, εἴτε προφάσει εἴτε ἀληθείᾳ, Χριστὸς καταγγέλλεται, καὶ ἐν τούτῳ χαίρω· ἀλλὰ καὶ χαρήσομαι,",
      "languageId": "html",
      "metadata": {
        "id": "af0cc9c3-8fde-42f7-bc6b-db18bc23a546",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:18",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "18",
        "cellLabel": "18",
        "originalText": "τί γάρ; πλὴν ὅτι παντὶ τρόπῳ, εἴτε προφάσει εἴτε ἀληθείᾳ, Χριστὸς καταγγέλλεται, καὶ ἐν τούτῳ χαίρω· ἀλλὰ καὶ χαρήσομαι,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "τί γάρ; πλὴν ὅτι παντὶ τρόπῳ, εἴτε προφάσει εἴτε ἀληθείᾳ, Χριστὸς καταγγέλλεται, καὶ ἐν τούτῳ χαίρω· ἀλλὰ καὶ χαρήσομαι,",
          "globalReferences": [
            "PHP 1:18"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "οἶδα γὰρ ὅτι τοῦτό μοι ἀποβήσεται εἰς σωτηρίαν διὰ τῆς ὑμῶν δεήσεως καὶ ἐπιχορηγίας τοῦ πνεύματος Ἰησοῦ Χριστοῦ,",
      "languageId": "html",
      "metadata": {
        "id": "5d9971f1-60fd-4d5a-a130-cc92fb01ed85",
        "type": "text",
        "edits": [],
        "vref": "PHP 1:19",
        "bookCode": "PHP",
        "chapter": 1,
        "verse": "19",
        "cellLabel": "19",
        "originalText": "οἶδα γὰρ ὅτι τοῦτό μοι ἀποβήσεται εἰς σωτηρίαν διὰ τῆς ὑμῶν δεήσεως καὶ ἐπιχορηγίας τοῦ πνεύματος Ἰησοῦ Χριστοῦ,",
        "fileName": "PHP.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "οἶδα γὰρ ὅτι τοῦτό μοι ἀποβήσεται εἰς σωτηρίαν διὰ τῆς ὑμῶν δεήσεως καὶ ἐπιχορηγίας τοῦ πνεύματος Ἰησοῦ Χριστοῦ,",
          "globalReferences": [
            "PHP 1:19"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "κατὰ τὴν ἀποκαραδοκίαν καὶ ἐλπίδα μου ὅτι ἐν οὐδενὶ αἰσχυνθήσομαι, ἀλλ’ ἐν πάσῃ παρρησίᾳ ὡς πάντοτε καὶ νῦν μεγαλυνθήσεται Χριστὸς ἐν τῷ σώματί μου, εἴτε διὰ ζωῆς εἴτε διὰ θανάτου.",
      "languageId": "html",
      "metadata": {
        "id": "3a6c8d27-6fba-4e35-9445-080a47795a90",
        "type": "text",
        "edits": [],
