        "bookCode": "PHP",
        "chapter": 4,
        "verse": "4",
        "cellLabel": "4",
        "originalText": "Χαίρετε ἐν κυρίῳ πάντοτε· πάλιν ἐρῶ, χαίρετε.",
        "fileName": "PHP.macula",
        "chapterNumber": "4",
        "data": {
          "originalText": "Χαίρετε ἐν κυρίῳ πάντοτε· πάλιν ἐρῶ, χαίρετε.",
          "globalReferences": [
            "PHP 4:4"
          ]
        }
      }
    },
    {
      "kind": 2,
      "value": "τὸ ἐπιεικὲς ὑμῶν γνωσθήτω πᾶσιν ἀνθρώποις. ὁ κύριος ἐγγύς·",
      "languageId": "html",
      "metadata": {
        "id": "d5d99d85-03b6-4ac4-a076-b155fec2ad1b",
        "type": "text",
        "edits": [],
