        "bookCode": "COL",
        "chapter": 4,
        "verse": "5",
        "cellLabel": "5",
        "originalText": "Ἐν σοφίᾳ περιπατεῖτε πρὸς τοὺς ἔξω, τὸν καιρὸν ἐξαγοραζόμενοι.",
        "fileName": "COL.macula",
        "chapterNumber": "4",
