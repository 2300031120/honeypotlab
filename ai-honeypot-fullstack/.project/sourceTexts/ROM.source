        "chapter": 8,
        "verse": "1",
        "cellLabel": "1",
        "originalText": "Οὐδὲν ἄρα νῦν κατάκριμα τοῖς ἐν Χριστῷ Ἰησοῦ·",
        "fileName": "ROM.macula",
        "chapterNumber": "8",
        "data": {
          "originalText": "Οὐδὲν ἄρα νῦν κατάκριμα τοῖς ἐν Χριστῷ Ἰησοῦ·",
