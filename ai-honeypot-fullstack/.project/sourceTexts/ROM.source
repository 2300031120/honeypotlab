        "type": "text",
        "edits": [],
        "vref": "ROM 14:1",
        "bookCode": "ROM",
        "chapter": 14,
        "verse": "1",
        "cellLabel": "1",
        "originalText": "Τὸν δὲ ἀσθενοῦντα τῇ πίστει προσλαμβάνεσθε, μὴ εἰς διακρίσεις διαλογισμῶν.",
        "fileName": "ROM.macula",
        "chapterNumber": "14",
        "data": {
          "originalText": "Τὸν δὲ ἀσθενοῦντα τῇ πίστει προσλαμβάνεσθε, μὴ εἰς διακρίσεις διαλογισμῶν.",
          "globalReferences": [
