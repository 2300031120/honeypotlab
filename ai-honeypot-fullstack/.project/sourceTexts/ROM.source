    },
    {
      "kind": 2,
      "value": "καὶ πάλιν λέγει· Εὐφράνθητε, ἔθνη, μετὰ τοῦ λαοῦ αὐτοῦ.",
      "languageId": "html",
      "metadata": {
        "id": "61f60830-f26f-4e24-b900-158ee8bcced7",
        "type": "text",
        "edits": [],
        "vref": "ROM 15:10",
        "bookCode": "ROM",
        "chapter": 15,
        "verse": "10",
        "cellLabel": "10",
        "originalText": "καὶ πάλιν λέγει· Εὐφράνθητε, ἔθνη, μετὰ τοῦ λαοῦ αὐτοῦ.",
        "fileName": "ROM.macula",
        "chapterNumber": "15",
        "data": {
          "originalText": "καὶ πάλιν λέγει· Εὐφράνθητε, ἔθνη, μετὰ τοῦ λαοῦ αὐτοῦ.",
