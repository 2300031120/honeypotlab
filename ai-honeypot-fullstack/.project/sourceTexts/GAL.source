        "vref": "GAL 5:16",
        "bookCode": "GAL",
        "chapter": 5,
        "verse": "16",
        "cellLabel": "16",
        "originalText": "Λέγω δέ, πνεύματι περιπατεῖτε καὶ ἐπιθυμίαν σαρκὸς οὐ μὴ τελέσητε.",
        "fileName": "GAL.macula",
        "chapterNumber": "5",
