        "bookCode": "LUK",
        "chapter": 1,
        "verse": "4",
        "cellLabel": "4",
        "originalText": "ἵνα ἐπιγνῷς περὶ ὧν κατηχήθης λόγων τὴν ἀσφάλειαν.",
        "fileName": "LUK.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "ἵνα ἐπιγνῷς περὶ ὧν κατηχήθης λόγων τὴν ἀσφάλειαν.",
