        "bookCode": "LUK",
        "chapter": 1,
        "verse": "12",
        "cellLabel": "12",
        "originalText": "καὶ ἐταράχθη Ζαχαρίας ἰδών, καὶ φόβος ἐπέπεσεν ἐπ’ αὐτόν.",
        "fileName": "LUK.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "καὶ ἐταράχθη Ζαχαρίας ἰδών, καὶ φόβος ἐπέπεσεν ἐπ’ αὐτόν.",
