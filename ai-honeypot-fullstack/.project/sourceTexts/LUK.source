    {
      "kind": 2,
      "value": "ἵνα ἐπιγνῷς περὶ ὧν κατηχήθης λόγων τὴν ἀσφάλειαν.",
      "languageId": "html",
      "metadata": {
        "id": "81d624ef-4b3e-4d6b-a63c-442fadf4bba1",
        "type": "text",
