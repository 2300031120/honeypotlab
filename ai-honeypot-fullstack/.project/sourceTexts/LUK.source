        "bookCode": "LUK",
        "chapter": 1,
        "verse": "1",
        "cellLabel": "1",
        "originalText": "Ἐπειδήπερ πολλοὶ ἐπεχείρησαν ἀνατάξασθαι διήγησιν περὶ τῶν πεπληροφορημένων ἐν ἡμῖν πραγμάτων,",
        "fileName": "LUK.macula",
        "chapterNumber": "1",
        "data": {
          "originalText": "Ἐπειδήπερ πολλοὶ ἐπεχείρησαν ἀνατάξασθαι διήγησιν περὶ τῶν πεπληροφορημένων ἐν ἡμῖν πραγμάτων,",
          "globalReferences": [
