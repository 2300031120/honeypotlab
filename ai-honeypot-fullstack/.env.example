APP_ENV=production
SECRET_KEY=REPLACE_WITH_STRONG_32_PLUS_CHAR_SECRET
PUBLIC_BASE_URL=https://honeypot.example.com
CORS_ORIGINS=https://honeypot.example.com
TRUSTED_HOSTS=honeypot.example.com,*.trycloudflare.com
FORCE_HTTPS_REDIRECT=true
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_SECONDS=31536000
SECURITY_CONTENT_SECURITY_POLICY=
DECOY_COOKIE_SECURE=true
DECOY_COOKIE_SAMESITE=lax
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
AI_GENERATION_TIMEOUT_SECONDS=25
AI_ADVISOR_TIMEOUT_SECONDS=45
AI_ADVISOR_MODEL=gemma3:4b
AI_ADVISOR_MAX_TOKENS=120
AI_ADVISOR_TEMPERATURE=0.2
AI_ADVISOR_WARMUP_ENABLED=true
AI_BREAKER_FAILURE_THRESHOLD=2
AI_BREAKER_COOLDOWN_SECONDS=30
AI_ADVISOR_BREAKER_FAILURE_THRESHOLD=4
AI_ADVISOR_BREAKER_COOLDOWN_SECONDS=20
OLLAMA_MODEL=llama3:latest
OLLAMA_REQUEST_TIMEOUT_SECONDS=45
OLLAMA_KEEP_ALIVE=10m
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
AUTO_BLOCK_REPEAT_ENABLED=true
AUTO_BLOCK_REPEAT_THRESHOLD=6
AUTO_BLOCK_WINDOW_MINUTES=20
AUTO_BLOCK_DURATION_HOURS=24
AUTO_BLOCK_MIN_SCORE=75
THREAT_ANALYSIS_AI_TIMEOUT_SECONDS=8
SHELL_RESPONSE_AI_TIMEOUT_SECONDS=8
TERMINAL_REAL_EXEC_ENABLED=true
TERMINAL_REQUIRE_AUTH_FOR_REAL_EXEC=true
TERMINAL_SAFE_MODE=true
TERMINAL_EXEC_TIMEOUT_SEC=8
TERMINAL_MAX_OUTPUT_CHARS=12000
TERMINAL_SANDBOX_ROOT=./backend/terminal_sandbox
TERMINAL_SHELL_MODE=auto
TERMINAL_WSL_DISTRO=
TLS_DOMAIN=example.com
TLS_EMAIL=security@example.com
DUCKDNS_DOMAIN=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
CLOUDFLARE_PUBLIC_HOSTNAME=honeypot.example.com
PROTOCOL_SSH_TRAP_CREDENTIALS=user1:pass1,user2:pass2
PROTOCOL_MYSQL_TRAP_CREDENTIALS=user1:pass1,user2:pass2
LEAD_NOTIFICATION_ENABLED=true
LEAD_NOTIFICATION_EMAIL_TO=security@example.com
LEAD_SLACK_WEBHOOK_URL=
LEAD_DEDUPE_WINDOW_MINUTES=720
LEAD_CHALLENGE_ENABLED=true
LEAD_CHALLENGE_TTL_SECONDS=600
LEAD_MIN_SUBMIT_SECONDS=3
LEAD_SPAM_SCORE_THRESHOLD=4
