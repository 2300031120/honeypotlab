COWRIE_TELNET_ENABLED=no
COWRIE_OUTPUT_JSONLOG_ENABLED=yes
COWRIE_SITE_ID=
COWRIE_JSON_LOG=/cowrie/cowrie-git/var/log/cowrie/cowrie.json
COWRIE_HTTP_TIMEOUT_SEC=4
COWRIE_BRIDGE_POLL_INTERVAL_SEC=2
TLS_DOMAIN=app.example.com
TLS_EMAIL=security@example.com
DUCKDNS_DOMAIN=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
