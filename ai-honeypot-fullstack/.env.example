APP_ENV=production
SECRET_KEY=REPLACE_WITH_STRONG_32_PLUS_CHAR_SECRET
PUBLIC_BASE_URL=https://app.example.com
VITE_PUBLIC_SITE_NAME=CyberSentil
VITE_PUBLIC_SHORT_NAME=CyberSentil
VITE_PUBLIC_BRAND_TEXT=CYBERSENTIL
VITE_PUBLIC_TAGLINE=AI deception for exposed routes
VITE_PUBLIC_SITE_DESCRIPTION=CyberSentil helps security teams deploy believable login, admin, and API decoys, capture attacker behavior early, and turn first-touch telemetry into analyst-ready evidence.
VITE_PUBLIC_SITE_URL=https://example.com
VITE_PUBLIC_APP_URL=https://app.example.com
VITE_PUBLIC_LOGIN_URL=https://app.example.com/auth/login
VITE_PUBLIC_COMPANY_NAME=CyberSentil
VITE_PUBLIC_CONTACT_EMAIL=contact@cybersentil.online
VITE_PUBLIC_SECURITY_EMAIL=security@cybersentil.online
VITE_PUBLIC_PRIVACY_EMAIL=privacy@cybersentil.online
VITE_PUBLIC_DEMO_BOOKING_URL=
VITE_PUBLIC_DEMO_BOOKING_LABEL=Book Live Slot
VITE_PUBLIC_SHOW_STATUS_PILL=false
LEAD_NOTIFICATION_BRAND_NAME=CyberSentil
LEAD_NOTIFICATION_CONTACT_EMAIL=contact@cybersentil.online
LEAD_NOTIFICATION_WEBHOOK_URL=
LEAD_NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=5
LEAD_NOTIFICATION_EMAIL_TO=
LEAD_AUTOREPLY_ENABLED=false
LEAD_AUTOREPLY_REPLY_TO=contact@cybersentil.online
LEAD_AUTOREPLY_DEMO_BOOKING_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CyberSentil
SMTP_USE_TLS=true
SMTP_USE_SSL=false
CORS_ORIGINS=https://example.com,https://app.example.com
TRUSTED_HOSTS=app.example.com,example.com,www.example.com,frontend,backend,*.trycloudflare.com
FORCE_HTTPS_REDIRECT=true
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_SECONDS=31536000
SECURITY_CONTENT_SECURITY_POLICY=
DECOY_COOKIE_SECURE=true
DECOY_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
LEAD_RATE_LIMIT_WINDOW_SECONDS=300
LEAD_RATE_LIMIT_MAX_ATTEMPTS=5
POSTGRES_DB=cybersentinel
POSTGRES_USER=cybersentinel
POSTGRES_PASSWORD=CHANGE_THIS_POSTGRES_PASSWORD
DATABASE_URL=postgresql://cybersentinel:CHANGE_THIS_POSTGRES_PASSWORD@postgres:5432/cybersentinel
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@cybersentil.online
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
ENABLE_DEMO_SEED=false
ALLOW_SIGNUP=false
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
AI_GENERATION_TIMEOUT_SECONDS=25
AI_ADVISOR_TIMEOUT_SECONDS=45
AI_ADVISOR_MODEL=gemma3:4b
AI_ADVISOR_MAX_TOKENS=120
AI_ADVISOR_TEMPERATURE=0.2
AI_ADVISOR_WARMUP_ENABLED=true
AI_BREAKER_FAILURE_THRESHOLD=2
AI_BREAKER_COOLDOWN_SECONDS=30
AI_ADVISOR_BREAKER_FAILURE_THRESHOLD=4
AI_ADVISOR_BREAKER_COOLDOWN_SECONDS=20
OLLAMA_MODEL=llama3:latest
OLLAMA_REQUEST_TIMEOUT_SECONDS=45
OLLAMA_KEEP_ALIVE=10m
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_VERIFY_TLS=true
SPLUNK_HEC_TIMEOUT_SECONDS=4
AUTO_BLOCK_REPEAT_ENABLED=true
AUTO_BLOCK_REPEAT_THRESHOLD=6
AUTO_BLOCK_WINDOW_MINUTES=20
AUTO_BLOCK_DURATION_HOURS=24
AUTO_BLOCK_MIN_SCORE=75
THREAT_ANALYSIS_AI_TIMEOUT_SECONDS=8
SHELL_RESPONSE_AI_TIMEOUT_SECONDS=8
TERMINAL_REAL_EXEC_ENABLED=true
TERMINAL_SANDBOX_URL=http://terminal-sandbox:5100
TERMINAL_REQUIRE_AUTH_FOR_REAL_EXEC=true
TERMINAL_SAFE_MODE=true
TERMINAL_EXEC_TIMEOUT_SEC=8
TERMINAL_MAX_OUTPUT_CHARS=12000
TERMINAL_SANDBOX_SESSION_TTL_SECONDS=7200
TERMINAL_SANDBOX_ROOT=./backend/terminal_sandbox
TERMINAL_SHELL_MODE=auto
TERMINAL_WSL_DISTRO=
PROTOCOL_SHARED_SECRET=CHANGE_THIS_INTERNAL_PROTOCOL_SECRET
SSH_DECOY_HEALTH_URL=http://ssh-decoy:5101/health
PROTOCOL_SSH_AUTH_TRAP_ENABLED=true
SSH_DECOY_PORT=2222
SSH_DECOY_SITE_ID=
SSH_DECOY_ACCEPT_ANY_PASSWORD=false
SSH_DECOY_SERVER_VERSION=OpenSSH_8.9p1 Ubuntu-3ubuntu0.6
SSH_DECOY_HTTP_TIMEOUT_SEC=4
