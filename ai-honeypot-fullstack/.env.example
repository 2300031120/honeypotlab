CLOUDFLARE_EDGE_BLOCK_API_BASE=https://api.cloudflare.com/client/v4
PROTOCOL_SSH_TRAP_CREDENTIALS=CHANGE_THIS_SSH_USER:CHANGE_THIS_SSH_PASSWORD,CHANGE_THIS_SSH_USER2:CHANGE_THIS_SSH_PASSWORD2
PROTOCOL_MYSQL_TRAP_CREDENTIALS=CHANGE_THIS_MYSQL_USER:CHANGE_THIS_MYSQL_PASSWORD,CHANGE_THIS_MYSQL_USER2:CHANGE_THIS_MYSQL_PASSWORD2
